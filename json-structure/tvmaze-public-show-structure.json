          "type": "string"
        }
      },
      {
        "name": "status",
        "type": "string",
        "description": "e.g. Running, Ended, To Be Determined"
      },
      {
        "name": "runtime",
        "type": "integer"
      },
      {
        "name": "averageRuntime",
        "type": "integer"
      },
      {
        "name": "premiered",

        "type": "reference"
      },
      {
        "name": "dvdCountry",
        "type": "reference"
      },
      {
        "name": "externals",
        "type": "reference",
        "ref": "#/components/schemas/Externals"
      },
      {
        "name": "image",
        "type": "reference"
      },
      {
        "name": "summary",
        "type": "string",
        "description": "HTML summary"
      },
      {
        "name": "updated",
        "type": "integer",
